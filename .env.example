# Public client config (Vite only exposes vars prefixed with VITE_)
#
# These values are embedded into the built client bundle at build time.
# Do NOT put any real secrets here (e.g. Supabase service role key).
#
# Local dev: copy these into `.env.local` and restart `npm run dev`.
# Production: set these in your hosting/build environment and rebuild.
# This file covers the app/Vercel side only; the separate cloud runner has its own env/secrets.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Optional wildcard root domain for per-app public webhook URLs.
# Example: example.com -> https://my-app-abc123.example.com/appstore-review?token=...
VITE_APPSTORE_REVIEW_PROXY_ROOT_DOMAIN=

# Server-side only (Vercel Functions). Do NOT prefix these with VITE_.
# These are secrets and must never be embedded into the client bundle.
SUPABASE_SERVICE_ROLE_KEY=
# Optional server-side wildcard root domain for clean per-app public webhook URLs.
APPSTORE_REVIEW_PROXY_ROOT_DOMAIN=
OPENAI_API_KEY=
REPLICATE_API_TOKEN=

# GitHub (server-side only). Used by the Vercel API helpers to create/delete repos and read main HEAD.
# Code-producing runner jobs use the cloud runner's own GitHub env/secrets instead.
GITHUB_TOKEN=
# Comma-separated GitHub usernames to add as collaborators to newly created repos.
GITHUB_DEFAULT_COLLABORATORS=
# Public target owner for the client repo publish workflow.
VITE_CLIENT_GITHUB_PUBLISH_OWNER=

# Supabase CLI deploy scripts. This is an identifier, not a secret, but keep live project refs local.
SUPABASE_PROJECT_REF=
