{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/(@.*)",
            "destination": "/$1"
        },
        {
            "source": "/(__.*)",
            "destination": "/$1"
        },
        {
            "source": "/(.*\\..*)",
            "destination": "/$1"
        },
        {
            "source": "/asomobile-api/:path*",
            "destination": "https://app.asomobile.net/asomobile-public-api/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
