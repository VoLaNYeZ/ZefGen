{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "appstore-review-bridge",
  "main": "worker.js",
  "compatibility_date": "2026-03-07",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "routes": [
    {
      "pattern": "*.example.com/*",
      "zone_name": "example.com"
    }
  ],
  "vars": {
    "PUBLIC_ROOT_DOMAIN": "example.com"
  }
}
